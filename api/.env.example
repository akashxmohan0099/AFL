# Optional shared API key for protected /api/* routes.
AFL_API_KEY=

# Header name expected for the API key.
AFL_API_KEY_HEADER=X-API-Key

# CORS policy for browser clients.
AFL_API_ALLOW_ORIGINS=http://localhost:3000
AFL_API_ALLOW_METHODS=GET,OPTIONS
AFL_API_ALLOW_HEADERS=Content-Type,X-API-Key
AFL_API_ALLOW_CREDENTIALS=false

# Basic in-memory rate limiting.
AFL_RATE_LIMIT_ENABLED=true
AFL_RATE_LIMIT_REQUESTS=240
AFL_RATE_LIMIT_WINDOW_SECONDS=60
AFL_RATE_LIMIT_EXEMPT_PATHS=/api/health,/docs,/openapi.json,/redoc

# Trust proxy-forwarded client IPs only behind a trusted proxy/load balancer.
AFL_TRUST_X_FORWARDED_FOR=false

# API log level for request logging and exceptions.
AFL_API_LOG_LEVEL=INFO

# Eager load the parquet cache on startup. Set false to lazy-load on first API request.
AFL_LOAD_CACHE_ON_STARTUP=true
